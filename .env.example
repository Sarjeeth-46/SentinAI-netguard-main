# =============================================================================
# SentinAI NetGuard — Local Development Environment
# =============================================================================
# DO NOT commit this file with real values.
# In production, all secrets are stored in AWS SSM Parameter Store.
# See deployment guide: deploy/aws_deployment_guide.md
# =============================================================================

# ─── Application Security ─────────────────────────────────────────────────────
# Required. Generate with: openssl rand -hex 32
SECRET_KEY=

# Set to False in production. True only for local dev (enables /docs, stack traces).
DEBUG=True

# Required. Generate with: openssl rand -hex 24
# Production: stored in SSM as /sentinai/prod/TELEMETRY_SHARED_SECRET
TELEMETRY_SHARED_SECRET=

# Comma-separated list of IPs allowed to ship logs to this backend.
# Production: e.g., 172.31.38.172
ALLOWED_SHIPPER_IPS=127.0.0.1,0.0.0.0

# Never True in production — emergency admin bypass backdoor
ALLOW_EMERGENCY_ADMIN=False

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Local dev: http://localhost:5173
# Production: https://d1234abcdef.cloudfront.net
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── Database ─────────────────────────────────────────────────────────────────
# Production: stored in SSM as /sentinai/prod/MONGO_URI
MONGO_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# ─── Redis (Optional) ─────────────────────────────────────────────────────────
# Leave as-is for local dev if Redis is running.
# On production t2.micro without Redis, the app falls back to in-memory limiting.
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1

# ─── Frontend Build Variables (set at npm run build time, not runtime) ────────
# These go in your CI pipeline or local shell, not in .env
# VITE_API_BASE_URL=https://api.yourdomain.com
# VITE_WS_URL=wss://api.yourdomain.com
