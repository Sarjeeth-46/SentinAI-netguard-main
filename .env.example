# --- Application Security ---
# REQUIRED: Must be set in production to a secure random string (e.g., openssl rand -hex 32)
SECRET_KEY=

DEBUG=False

# --- Database ---
MONGO_URI=mongodb://localhost:27017

# --- OCI Object Storage (Recommended for Long Term Logs) ---
OCI_CONFIG_PROFILE=DEFAULT
OCI_NAMESPACE=your_tenancy_namespace
OCI_BUCKET_NAME=sentinai-logs
OCI_REGION=us-ashburn-1

# --- Log Collector (HIDS) ---
TARGET_SERVER_IP=192.168.56.10
TARGET_SSH_USER=cloud
TARGET_SSH_KEY_PATH=/root/.ssh/id_rsa
